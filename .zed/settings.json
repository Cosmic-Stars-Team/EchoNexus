{
  "lsp": {
    "clangd": {
      "binary": {
        "arguments": [
          "--compile-commands-dir=build/debug",
          "--background-index",
          "--clang-tidy",
          "--header-insertion=iwyu",
          "--completion-style=detailed",
          "--function-arg-placeholders",
        ],
      },
    },
  },
  "format_on_save": "on",
  "languages": {
    "C++": {
      "format_on_save": "on",
    },
  },
}
